/target

# 配布バンドル（bundle.ps1 が生成。再生成可能なため除外）
/dist

# ビルド時に生成・取得される大きなバイナリ（再取得可能なため除外）
/tools/*.7z
/tools/*.exe
/tools/mpv-dev/libmpv-2.dll

# デバッグ用の一時出力
/mpv.log
/err.txt
/out.txt

# probe (mpv_d3d11_probe / overlay_probe / d2d_overlay_probe) のログ/キャプチャ
/probe-mpv.log
/probe.err.txt
/probe.out.txt
/d2d.err.txt

# 秘密情報（OAuth クライアント / トークン）
/client_secret.json
/auth.json

# デバッグ用 stderr キャプチャ
/dev*.txt
/devstderr.txt

# dev-tools 検証時の一時リダイレクト出力
/se*.txt
/so*.txt
