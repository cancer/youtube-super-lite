/target
# 検証時に別 target dir で吐かれる野良ビルド出力
/target-verify

# 配布バンドル（bundle.ps1 が生成。再生成可能なため除外）
/dist

# ビルド時に生成・取得される大きなバイナリ（再取得可能なため除外）
/tools/*.7z
/tools/*.exe
/tools/mpv-dev/libmpv-2.dll

# デバッグ用の一時出力
/mpv.log
/err.txt
/out.txt

# probe (mpv_d3d11_probe / overlay_probe / d2d_overlay_probe) のログ/キャプチャ
/probe-mpv.log
/probe.err.txt
/probe.out.txt
/d2d.err.txt

# 秘密情報（OAuth クライアント / トークン）
/client_secret.json
/auth.json

# デバッグ用 stderr キャプチャ
/dev*.txt
/devstderr.txt

# dev-tools 検証時の一時リダイレクト出力
/se*.txt
/so*.txt

# Claude Design の梱包材・素材（参照正典ではないため除外）
#  _export = ハンドオフ用エクスポート（design/直下の重複コピー）
#  uploads = キャンバスに貼り付けた生の参照画像
/design/_export/
/design/uploads/
#  screenshots = 指示/作業に使った画像（機微・履歴から除去済み）
/design/screenshots/

# poc-webview2-iframe (issue #16) の自動キャプチャ出力（画面BitBltのため他ウィンドウが
# 写り込むことがあり、再現可能な使い捨てデータなのでコミット対象外）
/poc-shots/
